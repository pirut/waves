{
  "expo": {
    "name": "Make Waves",
    "slug": "make-waves",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "waves",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F2E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.make-waves",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Make Waves uses your location to show events near you on the map."
      }
    },
    "android": {
      "package": "com.anonymous.makewaves",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F2E8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "@clerk/expo",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Make Waves uses your location to show events near you on the map."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.18.2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
