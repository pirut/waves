# ─── Convex ────────────────────────────────────────────────────────
# Get these from `npx convex dev` (writes to .env.local automatically for dev).
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
#
# In the Clerk Dashboard:
# 1. Enable Native API for the app
# 2. Activate the Convex integration
# 3. Copy the Clerk Frontend API URL / issuer domain
#
# Set the Convex backend issuer with:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# ─── Mapbox ────────────────────────────────────────────────────────
# Public token (pk.*) — used by both native (@rnmapbox/maps) and web (mapbox-gl).
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_public_token

# Secret download token (sk.*) — used only at build time by @rnmapbox/maps
# to fetch native SDK artifacts. Add this via `npx expo prebuild` env or EAS.
MAPBOX_DOWNLOAD_TOKEN=sk.your_download_token
