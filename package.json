{
  "name": "waves",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "sh ./scripts/run-ios-simulator.sh",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "dev": "concurrently -n convex,expo -c cyan,green \"npm:convex:dev\" \"npm:start\"",
    "typecheck": "tsc --noEmit",
    "convex:dev": "convex dev",
    "convex:push": "convex dev --once",
    "convex:seed": "convex run seed:run"
  },
  "dependencies": {
    "@clerk/expo": "^3.2.1",
    "@expo-google-fonts/instrument-serif": "^0.4.0",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "@gorhom/bottom-sheet": "^5.1.2",
    "@rnmapbox/maps": "^10.1.38",
    "convex": "^1.31.7",
    "culori": "^4.0.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "mapbox-gl": "^3.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-map-gl": "^7.1.7",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/culori": "^2.1.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.2"
  }
}
